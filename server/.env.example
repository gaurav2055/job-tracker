DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/jobtracker?schema=public
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
CORS_ORIGIN=https://your-app.vercel.app

# Base URL of the web app, used to build password reset links
CLIENT_URL=http://localhost:5173

# Gmail SMTP for sending password reset emails. Requires 2-Step Verification
# on the Google account + an App Password (myaccount.google.com > Security > App passwords).
# Leave unset in local dev — reset links are logged to the console instead.
EMAIL_USER=
EMAIL_APP_PASSWORD=
